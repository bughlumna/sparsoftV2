# backend/.env  — copy this to .env and fill in real values
# NEVER commit .env to version control

# Google OAuth Client ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Postgres connection string
# Local dev:  postgresql+asyncpg://postgres:password@localhost:5432/nqwest
# Railway:    injected automatically — just rename postgres:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nqwest

# Comma-separated list of allowed frontend origins
# Add your Railway frontend URL after deploying
ALLOWED_ORIGINS=https://nqwest-frontend.up.railway.app
