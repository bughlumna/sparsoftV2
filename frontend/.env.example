# ── Frontend environment variables ──────────────────────────────────────────
# Copy this file to .env (local dev) or set these in your Vercel project.

# Google OAuth Client ID (same value used by the backend)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Backend API base URL
#   Development : leave empty — Vite proxy forwards to localhost:8000
#   Production  : set to your Render service URL (no trailing slash)
VITE_API_URL=
